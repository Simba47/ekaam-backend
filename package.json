{
  "name": "scriptai-backend",
  "version": "1.0.0",
  "description": "ScriptAI Backend - AI-powered script generation platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --delay 1500 --exec \"tsx src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.24.1",
    "apify-client": "^2.9.4",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.1",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.2",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.38.0",
    "pg": "^8.13.1",
    "winston": "^3.15.0",
    "youtube-transcript": "^1.3.0",
    "yt-dlp-exec": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
